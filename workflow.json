    {
      "parameters": {
        "jsCode": "const NZT_OFFSET = 13; // NZDT (UTC+13); change to 12 after April 5 2026\n\nfunction toNZTDateStr(date) {\n  const nzt = new Date(date.getTime() + NZT_OFFSET * 3600000);\n  return nzt.toISOString().slice(0, 10);\n}\n\nfunction parseNZTStr(s) {\n  // \"2026-03-10 09:00\" stored as NZT \u2014 parse back to UTC\n  if (!s || s === 'PENDING') return null;\n  const cleaned = s.trim().replace(' ', 'T');\n  return new Date(cleaned + ':00+13:00');\n}\n\nfunction normalizePhone(phone) {\n  if (!phone) return null;\n  const c = phone.replace(/[\\s\\-\\(\\)]/g, '');\n  if (c.startsWith('0')) return '+64' + c.slice(1);\n  if (c.startsWith('+64')) return c;\n  return null;\n}\n\nconst MSG_INITIAL = \"Hi {name}, I help NZ agents auto-respond to Trade Me enquiries instantly \u2014 no missed leads when you're at an open home. Worth a chat? - Brandon\";\nconst MSG_F1 = \"Hey {name}, just following up. If you're not already sorted with automated lead follow-up, happy to show you what it looks like. - Brandon\";\nconst MSG_F2 = \"Last one from me {name} \u2014 if you'd like to see how it works, happy to send a short video or jump on a quick call. Otherwise no worries. - Brandon\";\n\nconst DAILY_CAP = 50;\nconst PER_RUN_CAP = 25;   // max new initial sends per run\nconst TOTAL_RUN_CAP = 25; // hard cap on total messages sent per run (initial + F1 + F2)\n\nconst now = new Date();\n\n// \u2500\u2500 Send window gate: Mon\u2013Fri 9:00am\u20134:30pm NZT only \u2500\u2500\nconst nztNow = new Date(now.getTime() + NZT_OFFSET * 3600000);\nconst nztHour = nztNow.getUTCHours();\nconst nztMinute = nztNow.getUTCMinutes();\nconst nztDay = nztNow.getUTCDay(); // 0=Sun, 1=Mon\u20265=Fri, 6=Sat\nconst isWeekday = nztDay >= 1 && nztDay <= 5;\nconst afterStart = nztHour >= 9;\nconst beforeEnd = nztHour < 16 || (nztHour === 16 && nztMinute <= 30);\nif (!isWeekday || !afterStart || !beforeEnd) return [];\n\nconst todayNZT = toNZTDateStr(now);\nconst rows = $input.all();\n\n// Count today's initial sends \u2014 includes PENDING rows (attempted sends count toward daily cap)\nlet todaySentCount = 0;\nfor (const item of rows) {\n  const g = (item.json['Initial Sent'] || '').trim();\n  if (!g) continue;\n  if (g === 'PENDING') {\n    // Count PENDING as today's attempt\n    todaySentCount++;\n    continue;\n  }\n  try {\n    const sentDate = toNZTDateStr(parseNZTStr(g));\n    if (sentDate === todayNZT) todaySentCount++;\n  } catch(e) {}\n}\n\nconst remaining = Math.max(0, DAILY_CAP - todaySentCount);\nconst initialCap = Math.min(remaining, PER_RUN_CAP);\n\nconst queue = [];\n\n// --- Initial sends ---\n// Eligible: Initial Sent is empty (not PENDING, not a timestamp)\nlet initialCount = 0;\nfor (const item of rows) {\n  if (initialCount >= initialCap) break;\n  const r = item.json;\n  const leadType = (r['Type'] || '').trim();\n  if (leadType === 'Commercial' || leadType === 'Property Management') continue;\n  const status = (r['Status'] || '').trim();\n  const g = (r['Initial Sent'] || '').trim();\n  if (g || status === 'Opted Out') continue; // skip if any value (incl. PENDING)\n  const mobile = (r['Mobile'] || '').trim();\n  const phone = normalizePhone(mobile);\n  if (!phone) continue;\n  const name = ((r['Name'] || '').split(' ')[0]) || 'there';\n  queue.push({\n    name, phone_e164: phone, original_mobile: mobile,\n    message: MSG_INITIAL.replace('{name}', name),\n    ts_col_name: 'Initial Sent', msg_col_name: 'Initial Message'\n  });\n  initialCount++;\n}\n\n// --- Followup 1 (3h+ after initial confirmed delivery) ---\n// Eligible: Initial Sent is a real timestamp (not PENDING), F1 Sent empty, no reply\nfor (const item of rows) {\n  const r = item.json;\n  const leadType = (r['Type'] || '').trim();\n  if (leadType === 'Commercial' || leadType === 'Property Management') continue;\n  const status = (r['Status'] || '').trim();\n  const g = (r['Initial Sent'] || '').trim();\n  const i = (r['F1 Sent'] || '').trim();\n  const replied = (r['Replied'] || '').trim();\n  if (!g || g === 'PENDING' || i || replied === 'Y' || status === 'Opted Out') continue;\n  const gTime = parseNZTStr(g);\n  if (!gTime) continue;\n  const hoursAgo = (now - gTime) / 3600000;\n  if (hoursAgo < 3) continue;\n  const mobile = (r['Mobile'] || '').trim();\n  const phone = normalizePhone(mobile);\n  if (!phone) continue;\n  const name = ((r['Name'] || '').split(' ')[0]) || 'there';\n  queue.push({\n    name, phone_e164: phone, original_mobile: mobile,\n    message: MSG_F1.replace('{name}', name),\n    ts_col_name: 'F1 Sent', msg_col_name: 'F1 Message'\n  });\n}\n\n// --- Followup 2 (21h+ after F1 confirmed delivery) ---\n// Eligible: F1 Sent is a real timestamp (not PENDING), F2 Sent empty, no reply\nfor (const item of rows) {\n  const r = item.json;\n  const leadType = (r['Type'] || '').trim();\n  if (leadType === 'Commercial' || leadType === 'Property Management') continue;\n  const status = (r['Status'] || '').trim();\n  const i = (r['F1 Sent'] || '').trim();\n  const k = (r['F2 Sent'] || '').trim();\n  const replied = (r['Replied'] || '').trim();\n  if (!i || i === 'PENDING' || k || replied === 'Y' || status === 'Opted Out') continue;\n  const iTime = parseNZTStr(i);\n  if (!iTime) continue;\n  const hoursAgo = (now - iTime) / 3600000;\n  if (hoursAgo < 21) continue;\n  const mobile = (r['Mobile'] || '').trim();\n  const phone = normalizePhone(mobile);\n  if (!phone) continue;\n  const name = ((r['Name'] || '').split(' ')[0]) || 'there';\n  queue.push({\n    name, phone_e164: phone, original_mobile: mobile,\n    message: MSG_F2.replace('{name}', name),\n    ts_col_name: 'F2 Sent', msg_col_name: 'F2 Message'\n  });\n}\n\nreturn queue.slice(0, TOTAL_RUN_CAP).map(item => ({ json: item }));"
      },
